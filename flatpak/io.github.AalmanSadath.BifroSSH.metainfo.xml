<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.AalmanSadath.BifroSSH</id>
  <name>BifroSSH</name>
  <summary>GUI SSH client with built-in SFTP and keychain management</summary>
  <metadata_license>FSFAP</metadata_license>
  <project_license>PolyForm-Noncommercial-1.0.0</project_license>
  <developer id="io.github.aalmansadath">
    <name>Aalman Sadath</name>
  </developer>
  <description>
    <p>BifroSSH is a modern SSH client with a full terminal emulator, SFTP file browser, SSH key management, per-server theming, and codeprints for quick command access.</p>
    <ul>
      <li>Full terminal emulator via xterm.js</li>
      <li>SFTP file browser with upload, download, and folder navigation</li>
      <li>SSH key management with encrypted local keychain</li>
      <li>Multiple sessions in tabs</li>
      <li>Customisable themes including a built-in theme editor</li>
      <li>Codeprints: named commands that can be pasted or run in any session</li>
    </ul>
  </description>
  <launchable type="desktop-id">io.github.AalmanSadath.BifroSSH.desktop</launchable>
